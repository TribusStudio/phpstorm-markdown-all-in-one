<idea-plugin>
    <id>com.tribus.markdown-all-in-one</id>
    <name>Markdown All-in-One</name>
    <vendor email="support@tribus.dev" url="https://github.com/tribus">Tribus</vendor>

    <description><![CDATA[
    <h2>Markdown All-in-One for PHPStorm</h2>
    <p>A comprehensive Markdown editing experience inspired by VSCode's Markdown All-in-One,
    purpose-built for the JetBrains ecosystem. No external dependencies required.</p>

    <h3>Features</h3>
    <ul>
        <li><b>Keyboard shortcuts</b> — Bold, italic, strikethrough, code spans, headings with platform-aware keys</li>
        <li><b>Smart list editing</b> — Auto-continue lists on Enter, indent/outdent, task list toggling, smart Backspace</li>
        <li><b>Table of Contents</b> — Generate, auto-update on save, multiple TOCs per document, named TOCs with attribute overrides</li>
        <li><b>Table formatting</b> — Auto-format GFM tables with alignment, Tab navigation between cells, format on save</li>
        <li><b>Live preview</b> — JCEF-based HTML preview with split editor, CSS themes (GitHub, GitHub Dark, GitLab, VSCode), custom CSS</li>
        <li><b>Auto-completion</b> — Heading references, file/image paths, reference link labels</li>
        <li><b>Smart paste</b> — Paste URLs over selected text to create markdown links</li>
        <li><b>Editor toolbar</b> — Persistent formatting toolbar with configurable display (icons/labels/both)</li>
        <li><b>Context menu</b> — Right-click context-aware actions, floating selection toolbar</li>
        <li><b>HTML export</b> — Export single files or batch folders to styled, self-contained HTML</li>
        <li><b>Selection wrapping</b> — Type *, ~, _, `, |, or - with text selected to wrap contextually</li>
        <li><b>File templates</b> — New > Markdown File with 6 templates (README, Document, Meeting Notes, etc.)</li>
    </ul>

    <h3>Getting Started</h3>
    <p>Install the plugin, disable the bundled "Markdown" plugin, and restart. Open any .md file to see
    the toolbar and preview. Configure in Settings &gt; Languages &gt; Markdown All-in-One.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!-- Register shortcuts on editor component for markdown files.
         EditorFactoryListener fires at editor creation time for reliable timing.
         Component-level shortcuts always override global keymap shortcuts,
         guaranteeing our actions fire instead of IDE builtins like GotoDeclaration. -->
    <applicationListeners>
        <listener class="com.tribus.markdown.editor.MarkdownFileEditorListener"
                  topic="com.intellij.openapi.editor.event.EditorFactoryListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File type and language support -->
        <fileType name="MarkdownAIO"
                  implementationClass="com.tribus.markdown.lang.MarkdownFileType"
                  fieldName="INSTANCE"
                  language="MarkdownAIO"
                  extensions="md;markdown;mdown;mkd;mkdn"/>

        <lang.parserDefinition language="MarkdownAIO"
                               implementationClass="com.tribus.markdown.lang.parser.MarkdownParserDefinition"/>

        <lang.syntaxHighlighterFactory language="MarkdownAIO"
                                       implementationClass="com.tribus.markdown.lang.highlighting.MarkdownSyntaxHighlighterFactory"/>

        <annotator language="MarkdownAIO"
                   implementationClass="com.tribus.markdown.lang.highlighting.MarkdownAnnotator"/>

        <!-- Settings page -->
        <applicationConfigurable
                id="com.tribus.markdown.settings"
                parentId="languages"
                displayName="Markdown All-in-One"
                instance="com.tribus.markdown.settings.MarkdownSettingsConfigurable"/>

        <applicationService
                serviceImplementation="com.tribus.markdown.settings.MarkdownSettings"/>

        <!-- Editor action handlers for smart keys -->
        <typedHandler
                implementation="com.tribus.markdown.editor.MarkdownTypedHandler"/>

        <enterHandlerDelegate
                implementation="com.tribus.markdown.editor.MarkdownEnterHandler"/>

        <backspaceHandlerDelegate
                implementation="com.tribus.markdown.editor.MarkdownBackspaceHandler"/>

        <!-- Auto-update TOC on save -->
        <fileDocumentManagerListener
                implementation="com.tribus.markdown.toc.TocAutoUpdateListener"/>

        <!-- Auto-format tables on save -->
        <fileDocumentManagerListener
                implementation="com.tribus.markdown.table.TableFormatOnSaveListener"/>

        <!-- Completion providers -->
        <completion.contributor language="MarkdownAIO"
                                implementationClass="com.tribus.markdown.completion.MarkdownCompletionContributor"
                                order="first"/>

        <!-- Smart paste (URL over selection creates markdown link) -->
        <copyPastePreProcessor
                implementation="com.tribus.markdown.editor.MarkdownSmartPasteProcessor"/>

        <!-- Tab navigation in tables -->
        <editorActionHandler action="EditorTab"
                             implementationClass="com.tribus.markdown.table.TableTabHandler"
                             order="first"/>
        <editorActionHandler action="EditorUnindentSelection"
                             implementationClass="com.tribus.markdown.table.TableShiftTabHandler"
                             order="first"/>

        <!-- Split editor with preview (editor | preview | split mode) -->
        <fileEditorProvider
                implementation="com.tribus.markdown.preview.MarkdownSplitEditorProvider"/>

        <!-- File templates for New > Markdown File -->
        <internalFileTemplate name="Blank Markdown"/>
        <internalFileTemplate name="README"/>
        <internalFileTemplate name="Document"/>
        <internalFileTemplate name="Meeting Notes"/>
        <internalFileTemplate name="Changelog"/>
        <internalFileTemplate name="API Documentation"/>
    </extensions>

    <actions>
        <group id="com.tribus.markdown.MainMenu"
               text="Markdown"
               description="Markdown All-in-One actions"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <!-- Formatting actions -->
            <!-- Shortcuts are registered in the keymap for discoverability (Settings > Keymap). -->
            <!-- MarkdownFileEditorListener re-registers them on the editor component so they -->
            <!-- override IDE builtins (GotoDeclaration, etc.) in markdown files. -->
            <action id="com.tribus.markdown.actions.ToggleBold"
                    class="com.tribus.markdown.actions.ToggleBoldAction"
                    text="Toggle Bold"
                    icon="/icons/toolbar-bold.svg"
                    description="Toggle bold formatting on selection">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl B"/>
            </action>

            <action id="com.tribus.markdown.actions.ToggleItalic"
                    class="com.tribus.markdown.actions.ToggleItalicAction"
                    text="Toggle Italic"
                    icon="/icons/toolbar-italic.svg"
                    description="Toggle italic formatting on selection">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl I"/>
            </action>

            <action id="com.tribus.markdown.actions.ToggleStrikethrough"
                    class="com.tribus.markdown.actions.ToggleStrikethroughAction"
                    text="Toggle Strikethrough"
                    icon="/icons/toolbar-strikethrough.svg"
                    description="Toggle strikethrough formatting on selection">
                <keyboard-shortcut keymap="$default" first-keystroke="alt S"/>
            </action>

            <action id="com.tribus.markdown.actions.ToggleCodeSpan"
                    class="com.tribus.markdown.actions.ToggleCodeSpanAction"
                    text="Toggle Code Span"
                    icon="/icons/toolbar-code.svg"
                    description="Toggle inline code formatting on selection">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_QUOTE"/>
            </action>

            <action id="com.tribus.markdown.actions.ToggleCodeBlock"
                    class="com.tribus.markdown.actions.ToggleCodeBlockAction"
                    text="Toggle Code Block"
                    icon="/icons/toolbar-codeblock.svg"
                    description="Toggle fenced code block on selection">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift BACK_QUOTE"/>
            </action>

            <separator/>

            <!-- Heading actions -->
            <action id="com.tribus.markdown.actions.HeadingUp"
                    class="com.tribus.markdown.actions.HeadingUpAction"
                    text="Increase Heading Level"
                    icon="/icons/toolbar-heading-up.svg"
                    description="Increase heading level (# to ##)">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift CLOSE_BRACKET"/>
            </action>

            <action id="com.tribus.markdown.actions.HeadingDown"
                    class="com.tribus.markdown.actions.HeadingDownAction"
                    text="Decrease Heading Level"
                    icon="/icons/toolbar-heading-down.svg"
                    description="Decrease heading level (## to #)">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift OPEN_BRACKET"/>
            </action>

            <separator/>

            <!-- List indent/outdent -->
            <action id="com.tribus.markdown.actions.ListIndent"
                    class="com.tribus.markdown.actions.ListIndentAction"
                    text="Indent List Item"
                    icon="/icons/toolbar-indent.svg"
                    description="Indent list item one level">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl CLOSE_BRACKET"/>
            </action>

            <action id="com.tribus.markdown.actions.ListOutdent"
                    class="com.tribus.markdown.actions.ListOutdentAction"
                    text="Outdent List Item"
                    icon="/icons/toolbar-outdent.svg"
                    description="Outdent list item one level">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl OPEN_BRACKET"/>
            </action>

            <separator/>

            <!-- TOC actions -->
            <action id="com.tribus.markdown.actions.CreateToc"
                    class="com.tribus.markdown.actions.CreateTocAction"
                    text="Create Table of Contents"
                    description="Insert table of contents at cursor"/>

            <action id="com.tribus.markdown.actions.UpdateToc"
                    class="com.tribus.markdown.actions.UpdateTocAction"
                    text="Update Table of Contents"
                    icon="/icons/toolbar-toc.svg"
                    description="Update existing table of contents"/>

            <action id="com.tribus.markdown.actions.AddSectionNumbers"
                    class="com.tribus.markdown.actions.AddSectionNumbersAction"
                    text="Add Section Numbers"
                    description="Add section numbers to headings"/>

            <action id="com.tribus.markdown.actions.RemoveSectionNumbers"
                    class="com.tribus.markdown.actions.RemoveSectionNumbersAction"
                    text="Remove Section Numbers"
                    description="Remove section numbers from headings"/>

            <separator/>

            <!-- Table actions -->
            <action id="com.tribus.markdown.actions.FormatTable"
                    class="com.tribus.markdown.actions.FormatTableAction"
                    text="Format Table"
                    icon="/icons/toolbar-table.svg"
                    description="Auto-format the GFM table at cursor">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift alt T"/>
            </action>

            <action id="com.tribus.markdown.actions.FormatAllTables"
                    class="com.tribus.markdown.actions.FormatAllTablesAction"
                    text="Format All Tables"
                    description="Auto-format all GFM tables in the document"/>

            <separator/>

            <!-- Math -->
            <action id="com.tribus.markdown.actions.ToggleMath"
                    class="com.tribus.markdown.actions.ToggleMathAction"
                    text="Toggle Math"
                    icon="/icons/toolbar-math.svg"
                    description="Cycle: plain → $inline$ → $$display$$ → plain">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl M"/>
            </action>

            <action id="com.tribus.markdown.actions.ToggleMathReverse"
                    class="com.tribus.markdown.actions.ToggleMathReverseAction"
                    text="Toggle Math (Reverse)"
                    description="Cycle: plain → $$display$$ → $inline$ → plain"/>

            <separator/>

            <!-- Export -->
            <action id="com.tribus.markdown.actions.ExportHtml"
                    class="com.tribus.markdown.actions.ExportHtmlAction"
                    text="Export to HTML"
                    description="Export current markdown file to HTML"/>

            <action id="com.tribus.markdown.actions.BatchExportHtml"
                    class="com.tribus.markdown.actions.BatchExportHtmlAction"
                    text="Batch Export to HTML"
                    description="Export all markdown files in a folder to HTML"/>
        </group>

        <!-- Task list toggle (standalone for keybinding) -->
        <action id="com.tribus.markdown.actions.ToggleTaskList"
                class="com.tribus.markdown.actions.ToggleTaskListAction"
                text="Toggle Task Checkbox"
                icon="/icons/toolbar-task.svg"
                description="Toggle task list checkbox state">
            <keyboard-shortcut keymap="$default" first-keystroke="alt C"/>
        </action>

        <!-- New > Markdown File (with template chooser) -->
        <action id="com.tribus.markdown.actions.CreateMarkdownFile"
                class="com.tribus.markdown.actions.CreateMarkdownFileAction"
                text="Markdown File"
                description="Create a new Markdown file from template">
            <add-to-group group-id="NewGroup" anchor="first"/>
        </action>

        <!-- Right-click context menu for markdown files -->
        <group id="com.tribus.markdown.ContextMenu"
               class="com.tribus.markdown.toolbar.MarkdownContextMenuGroup"
               text="Markdown"
               description="Markdown formatting and tools"
               popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </group>

        <!-- Generate menu (Cmd+N / Alt+Insert in editor) -->
        <group id="com.tribus.markdown.GenerateGroup"
               text="Markdown"
               description="Markdown generators"
               popup="true">
            <add-to-group group-id="GenerateGroup" anchor="first"/>

            <action id="com.tribus.markdown.generate.Table"
                    class="com.tribus.markdown.actions.generate.GenerateTableAction"
                    text="Table"
                    description="Insert a GFM table"/>

            <action id="com.tribus.markdown.generate.CodeBlock"
                    class="com.tribus.markdown.actions.generate.GenerateCodeBlockAction"
                    text="Code Block"
                    description="Insert a fenced code block"/>

            <action id="com.tribus.markdown.generate.Image"
                    class="com.tribus.markdown.actions.generate.GenerateImageAction"
                    text="Image"
                    description="Insert an image tag"/>

            <action id="com.tribus.markdown.generate.Footnote"
                    class="com.tribus.markdown.actions.generate.GenerateFootnoteAction"
                    text="Footnote"
                    description="Insert a footnote reference and definition"/>

            <action id="com.tribus.markdown.generate.LinkReference"
                    class="com.tribus.markdown.actions.generate.GenerateLinkReferenceAction"
                    text="Link Reference"
                    description="Insert a reference-style link"/>

            <action id="com.tribus.markdown.generate.FrontMatter"
                    class="com.tribus.markdown.actions.generate.GenerateFrontMatterAction"
                    text="Front Matter"
                    description="Insert YAML front matter"/>

            <action id="com.tribus.markdown.generate.TOC"
                    class="com.tribus.markdown.actions.CreateTocAction"
                    text="Table of Contents"
                    description="Insert table of contents from headings"/>
        </group>
    </actions>
</idea-plugin>
